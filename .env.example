# ============================================================
# AI Агент — конфігурація (шаблон)
# Скопіюй у .env і налаштуй під себе:  cp .env.example .env
#
# ПРИМІТКА: На Railway задавайте змінні через Railway Dashboard,
# вони матимуть пріоритет над цим файлом.
# ============================================================

# ╔══════════════════════════════════════════╗
# ║  LLM Backend: Ollama                      ║
# ╚══════════════════════════════════════════╝

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=8192
OLLAMA_TIMEOUT=120

# --- RAG ---
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.3
RAG_COLLECTION_NAME=knowledge_base
RAG_PERSIST_DIR=./data/chroma_db

# --- Skills DB ---
SKILLS_DB_PATH=./data/agent.db

# --- Database ---
# Тип БД: sqlite (дефолт, локалка) | postgres (деплой)
DATABASE_TYPE=sqlite

# PostgreSQL URL (потрібен тільки для DATABASE_TYPE=postgres)
# DATABASE_URL=postgresql://aegis:aegis_secret@localhost:5432/aegis

# Тип векторного стору: chroma (дефолт) | pgvector
VECTOR_STORE_TYPE=chroma

# --- Приклад для серверу (PostgreSQL + pgvector) ---
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://aegis:aegis_secret@localhost:5432/aegis
# VECTOR_STORE_TYPE=pgvector

# --- Tools ---
TOOLS_BROWSER_TIMEOUT=30
TOOLS_HEADLESS=true
TOOLS_WHATSAPP_SESSION=./data/whatsapp_session

# --- GUI ---
GUI_HOST=0.0.0.0
GUI_PORT=7860
DEBUG=true
KNOWLEDGE_BASE_DIR=./knowledge_base
