# ============================================================
# AI Агент — конфігурація (шаблон)
# Скопіюй у .env і налаштуй під себе:  cp .env.example .env
# ============================================================

# --- Ollama LLM ---
# URL Ollama сервера (локальний або віддалений)
# Приклад віддаленого: https://your-ollama.up.railway.app
OLLAMA_BASE_URL=http://localhost:11434
# Модель для чату (ollama pull <model>)
OLLAMA_MODEL=qwen2.5:7b
# Модель для ембеддингів
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Температура генерації (0.0 = детерміновано, 1.0 = креативно)
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.9
# Розмір контекстного вікна (токенів)
OLLAMA_NUM_CTX=8192
# Таймаут відповіді (секунд)
OLLAMA_TIMEOUT=120

# --- RAG ---
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.3
RAG_COLLECTION_NAME=knowledge_base
RAG_PERSIST_DIR=./data/chroma_db

# --- Skills DB ---
SKILLS_DB_PATH=./data/agent.db

# --- Tools ---
TOOLS_BROWSER_TIMEOUT=30
TOOLS_HEADLESS=true
TOOLS_WHATSAPP_SESSION=./data/whatsapp_session

# --- GUI ---
GUI_HOST=0.0.0.0
GUI_PORT=7860
DEBUG=true
KNOWLEDGE_BASE_DIR=./knowledge_base
